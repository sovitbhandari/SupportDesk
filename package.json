{
  "name": "zendesk-lite",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run api:dev\" \"npm run web:dev\"",
    "db:up": "docker compose up -d db redis mailhog",
    "db:down": "docker compose down",
    "db:migrate": "npm --workspace @zendesk-lite/db run migrate",
    "db:seed": "npm --workspace @zendesk-lite/db run seed",
    "db:verify-isolation": "npm --workspace @zendesk-lite/db run verify:isolation",
    "db:rollback": "npm --workspace @zendesk-lite/db run rollback",
    "api:dev": "npm --workspace @zendesk-lite/backend run dev",
    "api:start": "npm --workspace @zendesk-lite/backend run start",
    "api:typecheck": "npm --workspace @zendesk-lite/backend run typecheck",
    "worker:start": "npm --workspace @zendesk-lite/backend run start:worker",
    "worker:dev": "npm --workspace @zendesk-lite/backend run dev:worker",
    "web:dev": "npm --workspace @zendesk-lite/frontend run dev",
    "web:build": "npm --workspace @zendesk-lite/frontend run build",
    "web:typecheck": "npm --workspace @zendesk-lite/frontend run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
